{
  "name": "wio",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "pino-pretty": "^13.1.3",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/view": "^11.1.1",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.41.0",
    "@inquirer/prompts": "^8.3.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/ejs": "^3.1.5",
    "ejs": "^4.0.1",
    "fastify": "^5.7.1",
    "fastify-plugin": "^5.1.0",
    "fastify-socket.io": "^5.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "up": "docker compose up",
    "down": "docker compose down",
    "rebuild": "docker compose down && docker compose up --build --renew-anon-volumes",
    "nuke": "docker compose down -v && docker compose up --build --renew-anon-volumes",
    "logs": "docker compose logs -f",
    "lint": "bun eslint . --fix && bun prettier --write .",
    "lint:check": "bun eslint . && bun prettier --check .",
    "check": "bash dev/scripts/check.sh",
    "create-issues": "bash dev/scripts/create_issues.sh"
  },
  "bin": {
    "wio": "cli/index.ts"
  }
}
