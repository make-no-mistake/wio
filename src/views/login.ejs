<!DOCTYPE html>
<html lang="en" data-theme="dark">

<head>
  <link rel="icon" type="image/x-icon" href="/static/favicon/favicon.ico">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — wio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600&family=Instrument+Serif:ital@0;1&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/landing.css" />
  <link rel="stylesheet" href="/static/css/login.css" />
</head>

<body>
  <%- include('partials/nav') %>
    <main class="login-shell">
      <section class="login-card">
        <p class="login-eyebrow">Access your workspace</p>
        <h1 class="login-title">Log in with your user tag</h1>

        <form id="loginForm" class="login-form" novalidate>
          <label class="login-label" for="tagInput">User tag</label>
          <div class="login-input-row">
            <input id="tagInput" name="tag" type="text" inputmode="numeric" placeholder="1234 5678 9012 3456"
              autocomplete="off" required />
            <button id="loginBtn" class="login-btn" type="submit">Log in</button>
          </div>
          <p class="login-help">We only need your tag to authenticate. Keep it private.</p>
        </form>

        <p id="loginStatus" class="login-status"></p>
        <div class="login-actions">
          <a class="login-link" href="/register">Need a tag? Register</a>
          <a class="login-link" href="/">Back to Home</a>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
      <script src="/static/js/landing.js"></script>
      <script src="/static/js/login.js"></script>
</body>

</html>