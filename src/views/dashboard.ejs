<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wio Observability</title>
    <link rel="stylesheet" href="/static/css/dashboard.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-top">
                <a href="#" class="sidebar-icon active" data-target="view-overview" title="Dashboard">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                </a>
                <a href="#" class="sidebar-icon" data-target="view-traffic" title="Metrics">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                </a>
                <a href="#" class="sidebar-icon" data-target="view-events" title="Logs">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                </a>
            </div>
            <div class="sidebar-bottom">
                <a href="#" class="sidebar-icon" title="Support">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                </a>
                <a href="#" class="sidebar-icon" id="logoutBtn" title="Logout">
                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                </a>
            </div>
        </aside>

        <div class="main-wrapper">
            <!-- Header -->
            <header class="top-header">
                <div class="header-left">
                    <div class="logo">
                        <span class="logo-mark">W</span>
                        <span class="logo-text">Wio Observability</span>
                    </div>
                    <div class="site-selector">
                        <select id="siteSelect">
                            <option value="overview">All Sites (Overview)</option>
                            <% if (sites && sites.length > 0) { %>
                                <% sites.forEach(function(site) { %>
                                    <option value="<%= site.id %>"><%= site.name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                </div>
                
                <div class="header-center">
                    <nav class="nav-tabs">
                        <a href="#" class="tab active" data-target="view-overview">Overview</a>
                        <a href="#" class="tab" data-target="view-traffic">Traffic</a>
                        <a href="#" class="tab" data-target="view-events">Events</a>
                    </nav>
                </div>

                <div class="header-right">
                    <button class="icon-btn" id="themeToggleBtn" title="Toggle Theme">
                        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                    </button>
                    <button class="icon-btn"><svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg></button>
                </div>
            </header>

            <!-- Main Content -->
            <main class="content-area">
                <div id="view-overview" class="view-section active">
                    <!-- Summary Row -->
                    <div class="kpi-grid">
                        <div class="card kpi-card">
                            <div class="kpi-header">
                                <h3 class="card-title">Total Events</h3>
                                <span class="badge trend-up">Trend ↗</span>
                            </div>
                            <div class="kpi-value">1.25M</div>
                            <div class="kpi-sub kpi-positive">+8.4% vs 24h</div>
                        </div>
                        <div class="card kpi-card">
                            <div class="kpi-header">
                                <h3 class="card-title">Active Connections</h3>
                                <button class="btn-more">...</button>
                            </div>
                            <div class="kpi-value">482</div>
                            <div class="kpi-sub kpi-negative">-3.1% vs hour</div>
                        </div>
                        <div class="card kpi-card">
                            <div class="kpi-header">
                                <h3 class="card-title">Avg Response Time</h3>
                                <button class="btn-more">...</button>
                            </div>
                            <div class="kpi-value">185ms</div>
                            <div class="kpi-sub kpi-positive">-12.7% vs hour</div>
                        </div>
                    </div>

                    <!-- Middle Row: Charts -->
                    <div class="dashboard-grid middle-row">
                        <div class="card large-chart-card">
                            <div class="card-header">
                                <h3 class="card-title">Page Views Over Time</h3>
                            </div>
                            <div class="card-body">
                                <canvas id="pageViewsChart"></canvas>
                            </div>
                        </div>
                        <div class="card small-table-card">
                            <div class="card-header">
                                <h3 class="card-title">Top Paths</h3>
                                <button class="btn-more">...</button>
                            </div>
                            <div class="card-body table-container">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Path</th>
                                            <th>Total Hits</th>
                                            <th>Avg Response (ms)</th>
                                            <th>Error Rate</th>
                                        </tr>
                                    </thead>
                                    <tbody id="topPathsBody">
                                        <tr><td colspan="4">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom Row: Events -->
                    <div class="dashboard-grid bottom-row">
                        <div class="card large-chart-card">
                            <div class="card-header">
                                <h3 class="card-title">Event Count over Time</h3>
                            </div>
                            <div class="card-body">
                                <canvas id="eventsChart"></canvas>
                            </div>
                        </div>
                        <div class="card small-table-card">
                            <div class="card-header">
                                <h3 class="card-title">Recent Events</h3>
                                <button class="btn-more">...</button>
                            </div>
                            <div class="card-body table-container">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Timestamp</th>
                                            <th>Event Type</th>
                                            <th>Resource</th>
                                            <th>Status</th>
                                            <th>Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody id="recentEventsBody">
                                        <tr><td colspan="5">Loading...</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="view-traffic" class="view-section hidden">
                    <div class="dashboard-grid middle-row">
                        <div class="card large-chart-card">
                            <div class="card-header">
                                <h3 class="card-title">Traffic Volume</h3>
                            </div>
                            <div class="card-body">
                                <canvas id="trafficVolumeChart"></canvas>
                            </div>
                        </div>
                        <div class="card small-table-card">
                            <div class="card-header">
                                <h3 class="card-title">Status Codes</h3>
                            </div>
                            <div class="card-body" style="display:flex; justify-content:center; align-items:center; height: 100%;">
                                <canvas id="statusCodesChart" style="max-height: 200px;"></canvas>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card" style="margin-top: 24px;">
                        <div class="card-header">
                            <h3 class="card-title">All Paths</h3>
                        </div>
                        <div class="card-body table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Path</th>
                                        <th>Total Hits</th>
                                        <th>Avg Response (ms)</th>
                                        <th>Max Response (ms)</th>
                                    </tr>
                                </thead>
                                <tbody id="allPathsBody">
                                    <tr><td colspan="4">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div id="view-events" class="view-section hidden">
                    <div class="card">
                        <div class="card-header" style="display:flex; gap: 16px; align-items: center;">
                            <h3 class="card-title" style="flex:1">Log Explorer</h3>
                            <select id="eventFilterType" class="chart-select">
                                <option value="all">All Events</option>
                                <option value="api">API Requests</option>
                                <option value="ws">WebSockets</option>
                                <option value="ai">AI Prompts</option>
                            </select>
                        </div>
                        <div class="card-body table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>Event Type</th>
                                        <th>Resource / Details</th>
                                        <th>Status</th>
                                        <th>Duration</th>
                                    </tr>
                                </thead>
                                <tbody id="logExplorerBody">
                                    <tr><td colspan="5">Loading...</td></tr>
                                </tbody>
                            </table>
                            <div style="text-align:center; padding: 16px;">
                                <button id="loadMoreLogsBtn" style="background:none; border:1px solid var(--border); padding: 8px 16px; border-radius: 4px; cursor: pointer; color: var(--text-sec); font-size: 13px;">Load More</button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    
    <script src="/static/js/dashboard.js"></script>
</body>
</html>
