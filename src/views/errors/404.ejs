<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Page Not Found</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/landing.css" />
  <link rel="stylesheet" href="/static/css/login.css" />
  <link rel="stylesheet" href="/static/css/404.css" />
</head>
<body>
  <%- include('partials/nav') %>

  <main class="login-shell">
    <section class="login-card error-card">
      <p class="login-eyebrow">Page Not Found</p>
      <h1 class="login-title">404</h1>
      <p class="login-subhead error-subhead">
        The page you are looking for does not exist or may have moved.
      </p>

      <div class="login-actions error-actions">
        <a class="login-btn" href="https://wio.onl">Go to Home</a>
        <a class="login-btn ghost" href="/login">Go to Login</a>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="/static/js/landing.js"></script>
</body>
</html>

