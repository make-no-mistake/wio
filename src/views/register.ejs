<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register — User Tag</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/css/register.css" />
</head>
<body>
  <main class="page">
    <section class="card">
      <p class="eyebrow">Registration</p>
      <h1>Your User Tag</h1>
      <p class="subhead">Make No Mistake... </p>
      <div class="tag-row">
        <code id="tagValue" class="tag">Generating…</code>
        <button id="copyBtn" class="btn" type="button" disabled>Copy</button>
      </div>
      <div class="actions">
        <button id="regenBtn" class="btn ghost" type="button">Generate Another</button>
        <a class="link" href="/">Back to Home</a>
      </div>
      <p id="status" class="status"></p>
    </section>
  </main>
  <script src="/static/js/register.js"></script>
</body>
</html>
